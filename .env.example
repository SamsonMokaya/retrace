# Copy this file to .env and fill in your values. Do not commit .env.

# AWS Bedrock: required for embeddings and chat (Nova Lite).
# Get a bearer token from aws bedrock
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_token_or_leave_empty_if_using_iam
AWS_REGION=us-east-1

# Optional: use "nova" for Nova embeddings (if accessible); default is "titan"
# EMBEDDING_MODEL=titan
